# ==========================================
# ROOT CONFIGURATION (save as .env in the root directory)
# ==========================================
# Your actual domain name pointing to the VPS IP address.
# Caddy will automatically fetch a free HTTPS certificate for it!
DOMAIN=devmatch.yourdomain.com

# ==========================================
# BACKEND CONFIGURATION (save as backend/.env)
# ==========================================
NODE_ENV=production

# Internal Docker network URLs (DO NOT change these)
DATABASE_URL=postgresql://devmatch:devmatch_secret@postgres:5432/devmatch
REDIS_URL=redis://redis:6379

# Update this to match your real domain with https://
FRONTEND_URL=https://devmatch.yourdomain.com

# Create a strong random string for production!!!
JWT_SECRET=super_secret_production_key_change_me
PORT=3001

# ==========================================
# FRONTEND CONFIGURATION (save as frontend/.env)
# ==========================================
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=/api
BACKEND_API_URL=http://backend:3001
