{$DOMAIN:localhost} {
  # Forward API requests to the backend (stripping the /api prefix)
  handle_path /api/* {
    reverse_proxy backend:3001
  }

  # Forward WebSocket requests to the backend (no prefix stripping)
  handle /socket.io/* {
    reverse_proxy backend:3001
  }

  # Forward everything else to the Next.js frontend
  handle {
    reverse_proxy frontend:3000
  }
}
