    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/passport-github2": "^1.2.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3"
  }
